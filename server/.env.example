# پورت سرور
PORT=3000

# مسیر ذخیره داده (پیش‌فرض: ./data)
DATA_DIR=./data

# رمز امضای توکن — یک رشته‌ی تصادفی بلند بگذار
JWT_SECRET=change-this-to-a-long-random-string

# توکن ادمین برای endpointهای /admin (ساخت کد اشتراک، پاسخ به سوالات)
ADMIN_TOKEN=change-this-admin-token

# --- پنل پیامک ---
# اگر هیچ‌کدام تنظیم نشود، حالت console فعال می‌شود و کد فقط در لاگ سرور چاپ می‌شود (فقط برای تست).
# SMS_PROVIDER=kavenegar        # یا smsir
# KAVENEGAR_API_KEY=...
# KAVENEGAR_TEMPLATE=...         # نام الگوی تأییدشده در پنل کاوه‌نگار
# SMSIR_API_KEY=...
# SMSIR_TEMPLATE_ID=...
# SMSIR_PARAM_NAME=CODE

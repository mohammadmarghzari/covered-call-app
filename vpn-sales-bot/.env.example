# ==========================================================================
#  VPN Sales Bot — Environment configuration
#  Copy this file to `.env` and fill in the real values.
# ==========================================================================

# --- Telegram -------------------------------------------------------------
# Bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Numeric Telegram user IDs of the admins (comma separated). Get yours from @userinfobot
ADMIN_IDS=111111111,222222222

# The channel where receipts are posted and configs are delivered by replying.
# The bot MUST be an admin of this channel.
# You may provide ANY of these forms:
#   -1001234567890        (numeric id — required for PRIVATE channels)
#   @my_channel           (public channel username)
#   https://t.me/my_channel  (public channel link)
# For a public channel the bot resolves the numeric id automatically on startup.
ADMIN_CHANNEL_ID=https://t.me/my_channel

# --- Database (PostgreSQL) ------------------------------------------------
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=vpnbot
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full async SQLAlchemy URL (built from the values above, override if needed)
DATABASE_URL=postgresql+asyncpg://vpnbot:change_me_strong_password@db:5432/vpnbot

# --- Optional: proxy for reaching Telegram --------------------------------
# Leave EMPTY if the server can reach api.telegram.org directly.
# If Telegram is filtered on your server (common on some Iran-based hosts),
# set an HTTP or SOCKS5 proxy here, e.g.:
#   TELEGRAM_PROXY=http://127.0.0.1:8888
#   TELEGRAM_PROXY=socks5://user:pass@127.0.0.1:1080
TELEGRAM_PROXY=

# --- Redis (FSM storage + rate limiting) ----------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- Behaviour ------------------------------------------------------------
# Anti-spam: max messages allowed per RATE_LIMIT_WINDOW seconds per user
RATE_LIMIT_MESSAGES=5
RATE_LIMIT_WINDOW=3
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Default currency label shown to the user
CURRENCY=تومان
# Timezone used for timestamps
TIMEZONE=Asia/Tehran
